## Calculando a taxa de erro
prev = NULL
taxa_erro = NULL
suppressWarnings(
for(i in 1:20){
set.seed(101)
prev = knn(train = dados_treino, test = dados_teste, cl = dados_treino_labels, k = i)
taxa_erro[i] = mean(dados$diagnosis != prev)
})
